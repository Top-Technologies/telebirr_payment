<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- Sales Order Button -->
    <!-- ===================================================== -->

    <record id="view_sale_order_form_inherit_telebirr"
            model="ir.ui.view">
        <field name="name">sale.order.form.telebirr</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Add button inside header -->
            <xpath expr="//header" position="inside">

                <button name="action_telebirr_payment_wizard"
                        type="object"
                        string="Telebirr Payment Request"
                        class="btn-primary"
                        icon="fa-credit-card"
                        invisible="state not in ['sale', 'done']"/>

            </xpath>

        </field>
    </record>


    <!-- ===================================================== -->
    <!-- Invoice Button -->
    <!-- ===================================================== -->

    <record id="view_move_form_inherit_telebirr"
            model="ir.ui.view">
        <field name="name">account.move.form.telebirr</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Add button inside header -->
            <xpath expr="//header" position="inside">

                <button name="action_telebirr_payment_wizard"
                        type="object"
                        string="Telebirr Payment Request"
                        class="btn-primary"
                        icon="fa-credit-card"
                        invisible="state != 'posted' or payment_state == 'paid'"/>

            </xpath>

        </field>
    </record>

</odoo>