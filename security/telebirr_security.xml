<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Telebirr Security Rules -->
    
    <!-- Record Rules for Telebirr Config -->
    <record id="rule_telebirr_config_company" model="ir.rule">
        <field name="name">Telebirr Config: Multi-company</field>
        <field name="model_id" ref="model_telebirr_config"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_multi_company'))]"/>
    </record>
    
    <!-- Record Rules for Telebirr Transaction -->
    <record id="rule_telebirr_transaction_company" model="ir.rule">
        <field name="name">Telebirr Transaction: Multi-company</field>
        <field name="model_id" ref="model_telebirr_transaction"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_multi_company'))]"/>
    </record>
    
    <!-- Record Rules for Telebirr Transaction - User can see their own -->
    <record id="rule_telebirr_transaction_user" model="ir.rule">
        <field name="name">Telebirr Transaction: User Access</field>
        <field name="model_id" ref="model_telebirr_transaction"/>
        <field name="domain_force">[
            '|',
            ('create_uid', '=', user.id),
            ('partner_id', '=', user.partner_id.id)
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <!-- Security Groups -->
    <record id="group_telebirr_user" model="res.groups">
        <field name="name">Telebirr User</field>
        <field name="category_id" ref="base.module_category_accounting"/>
        <field name="comment">Can initiate Telebirr payments and view own transactions</field>
    </record>
    
    <record id="group_telebirr_manager" model="res.groups">
        <field name="name">Telebirr Manager</field>
        <field name="category_id" ref="base.module_category_accounting"/>
        <field name="implied_ids" eval="[(4, ref('group_telebirr_user'))]"/>
        <field name="comment">Can manage Telebirr configurations and all transactions</field>
    </record>
    
    <!-- Menu Access -->
    <record id="menu_telebirr_root" model="ir.ui.menu">
        <field name="name">Telebirr</field>
        <field name="parent_id" ref="account.menu_finance_receivables"/>
        <field name="sequence">50</field>
    </record>
    
    <!-- Update Access Rights for Groups -->
    <record id="access_telebirr_config_telebirr_user" model="ir.model.access">
        <field name="name">Telebirr Config: Telebirr User</field>
        <field name="model_id" ref="model_telebirr_config"/>
        <field name="group_id" ref="group_telebirr_user"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <record id="access_telebirr_config_telebirr_manager" model="ir.model.access">
        <field name="name">Telebirr Config: Telebirr Manager</field>
        <field name="model_id" ref="model_telebirr_config"/>
        <field name="group_id" ref="group_telebirr_manager"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <record id="access_telebirr_transaction_telebirr_user" model="ir.model.access">
        <field name="name">Telebirr Transaction: Telebirr User</field>
        <field name="model_id" ref="model_telebirr_transaction"/>
        <field name="group_id" ref="group_telebirr_user"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <record id="access_telebirr_transaction_telebirr_manager" model="ir.model.access">
        <field name="name">Telebirr Transaction: Telebirr Manager</field>
        <field name="model_id" ref="model_telebirr_transaction"/>
        <field name="group_id" ref="group_telebirr_manager"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
    <record id="access_telebirr_payment_wizard_telebirr_user" model="ir.model.access">
        <field name="name">Telebirr Payment Wizard: Telebirr User</field>
        <field name="model_id" ref="model_telebirr_payment_wizard"/>
        <field name="group_id" ref="group_telebirr_user"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <record id="access_telebirr_payment_wizard_telebirr_manager" model="ir.model.access">
        <field name="name">Telebirr Payment Wizard: Telebirr Manager</field>
        <field name="model_id" ref="model_telebirr_payment_wizard"/>
        <field name="group_id" ref="group_telebirr_manager"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
</odoo>
